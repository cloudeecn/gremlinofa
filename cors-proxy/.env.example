# Server port (default: 3002)
PORT=3002

# CORS origin (empty = same-domain only, * = allow all, single origin, or comma-separated list)
# Examples:
#   CORS_ORIGIN=https://example.com
#   CORS_ORIGIN=https://app.example.com,https://staging.example.com
#   CORS_ORIGIN=*
CORS_ORIGIN=

# Allowed target domains (comma-separated, empty = allow all for dev)
# Example: api.openai.com,generativelanguage.googleapis.com,api.anthropic.com
ALLOWED_TARGETS=

# Proxy request timeout in ms (default: 120000 = 2 minutes)
PROXY_TIMEOUT=120000
