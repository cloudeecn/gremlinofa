# Server port (default: 3004)
PORT=3004

# CORS origin (empty = same-domain only, * = allow all, single origin, or comma-separated list)
CORS_ORIGIN=

# SQLite database file path (default: ./touch-grass.db)
DB_PATH=./touch-grass.db

# API password - shared secret for minion tool callers (required)
API_PASSWORD=change-me

# Web UI password - for human operators accessing the web interface (required)
WEB_PASSWORD=change-me

# Long-poll timeout in ms per request (default: 30000 = 30s)
POLL_TIMEOUT_MS=30000

# Total timeout for a remote minion call in ms (default: 600000 = 10 minutes)
# The minion tool will retry long-polls until this total is exceeded
REMOTE_TIMEOUT_MS=600000
