# Server port (default: 3003)
PORT=3003

# CORS origin (empty = same-domain only, * = allow all, single origin, or comma-separated list)
# Examples:
#   CORS_ORIGIN=https://example.com
#   CORS_ORIGIN=https://app.example.com,https://staging.example.com
#   CORS_ORIGIN=*
CORS_ORIGIN=

# Root directory for all user files (default: ./data)
DATA_DIR=./data

# Server-wide password for Basic Auth validation (empty = dev mode, skip password check)
AUTH_PASSWORD=
